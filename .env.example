VITE_TWITCH=sakanine
VITE_YOUTUBE=YOUR_YOUTUBE_CHANNEL_ID
VITE_X=@YOUR_X_HANDLE
VITE_DONERU=YOUR_DONERU_NAME
# 公開サイトのベースURL（末尾スラッシュなし）
# 例: https://example.com
VITE_SITE_URL=https://example.com

# フッター CONTACT に表示するメール（未設定なら非表示）
VITE_CONTACT_EMAIL=your-email@example.com
# フッター Discord 行（未設定なら非表示）：招待 URL または表示テキスト
VITE_DISCORD_LINE=https://discord.gg/your-invite-code

# 最新アクティビティ（未設定のソースはスキップされます）
# YouTube Data API v3 のブラウザキー（HTTP リファラー制限推奨）
VITE_YOUTUBE_API_KEY=YOUR_YOUTUBE_API_KEY
# Twitch Helix 用認証情報
VITE_TWITCH_CLIENT_ID=YOUR_TWITCH_CLIENT_ID
# `Bearer ` プレフィックス有無どちらでも可
VITE_TWITCH_ACCESS_TOKEN="YOUR_TWITCH_ACCESS_TOKEN"

# Cloudflare Functions（/api/activity-feed）用シークレット
# 本番ではこちらを設定し、フロント公開される VITE_* には秘密情報を置かない
# 取得間隔（秒）。未設定時は ACTIVITY_FEED_CACHE_TTL_SECONDS を参照
ACTIVITY_FEED_FETCH_INTERVAL_SECONDS=120
ACTIVITY_FEED_CACHE_TTL_SECONDS=120
ACTIVITY_FEED_MAX_PER_SOURCE=6
ACTIVITY_FEED_MAX_MERGED=9
ACTIVITY_FEED_X_MAX_RESULTS=10
YOUTUBE_API_KEY=YOUR_YOUTUBE_API_KEY
TWITCH_CLIENT_ID=YOUR_TWITCH_CLIENT_ID
TWITCH_ACCESS_TOKEN="YOUR_TWITCH_ACCESS_TOKEN"
X_BEARER_TOKEN=YOUR_X_BEARER_TOKEN
X_USER_ID=YOUR_X_USER_ID
# X は username ではなく ID 指定のみ対応
# 任意（未設定なら VITE_TWITCH を利用）
TWITCH_LOGIN=YOUR_TWITCH_LOGIN

# アクティビティカードのサムネを常にダミー画像にする: true / 1
VITE_USE_DUMMY_ACTIVITY_THUMBS=false

# Twitch 埋め込みの parent に追加するホスト（カンマ区切り）
# VITE_TWITCH_EMBED_EXTRA_PARENTS=example.com,www.example.com

# アクセス元の国コード JSON を返す任意エンドポイント
# 例: {"country":"JP"} / {"countryCode":"JP"} / {"country_code":"JP"}
# VITE_GEO_COUNTRY_ENDPOINT=https://your-api.example.com/geo/country

# 開発検証用: 国コードベース言語判定の上書き
# JP=日本語, CN=中国語, KR=韓国語, その他=英語
# VITE_GEO_COUNTRY_OVERRIDE=KR
